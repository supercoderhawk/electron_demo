# Runtime release line (modern | legacy)
RELEASE_LINE=modern

# Set to 1 to disable updater in runtime
DISABLE_APP_UPDATER=0

# GitHub token for electron-builder --publish always
GH_TOKEN=

# Optional signing placeholders
# CSC_LINK=
# CSC_KEY_PASSWORD=
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
