{
  "name": "electron-demo",
  "version": "1.0.0",
  "description": "Electron dual-track starter with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "supercoderhawk",
  "homepage": "https://github.com/supercoderhawk/electron_demo",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "lint": "eslint --cache .",
    "format": "prettier --write .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "build": "pnpm typecheck && electron-vite build",
    "dist:win": "pnpm build && electron-builder --win nsis --x64 --ia32",
    "dist:linux": "pnpm build && electron-builder --linux AppImage deb --x64",
    "dist:mac": "pnpm build && electron-builder --mac dmg zip --x64 --arm64",
    "dist:mac:all": "pnpm build && electron-builder --mac dmg zip --x64 --arm64 --universal",
    "release": "pnpm build && electron-builder --publish always",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@tanstack/react-query": "^5.90.21",
    "electron-updater": "^6.8.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.13.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-env": "^10.1.0",
    "electron": "22.3.27",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md,css,scss,html}": "prettier --write"
  },
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
